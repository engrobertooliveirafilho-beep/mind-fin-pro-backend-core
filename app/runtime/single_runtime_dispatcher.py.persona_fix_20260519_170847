from app.runtime.whatsapp_trace_sensor import new_trace,add_event,save_trace,sanitize_final_output,assert_clean_output

def traced_whatsapp_reply(sender_id,user_message,producer):
    trace=new_trace(sender_id,user_message)
    add_event(trace,"input","single_runtime_dispatcher","traced_whatsapp_reply",user_message,"")
    try:
        raw=producer(sender_id,user_message)
        add_event(trace,"producer_output",getattr(producer,"__module__","unknown"),getattr(producer,"__name__","unknown"),user_message,raw)
    except Exception as e:
        raw=f"erro controlado: {type(e).__name__}"
        add_event(trace,"producer_error","single_runtime_dispatcher","producer",user_message,raw,{"error":str(e)[:240]})
    clean=sanitize_final_output(user_message,raw)
    ok,hits=assert_clean_output(clean)
    add_event(trace,"final_guard","single_runtime_dispatcher","sanitize_final_output",raw,clean,{"clean":ok,"hits":hits})
    save_trace(trace)
    return clean
